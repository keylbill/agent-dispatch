# =============================================================================
# Agent Dispatch — Environment Variables
# =============================================================================

# --- Bridge Server ---
PORT=3001
HOST=0.0.0.0

# --- Linear OAuth App ---
# Create at: https://linear.app/settings/api/applications/new
# Enable: Agent session events webhook
# Set redirect URI to: http://localhost:3001/oauth/callback
# Set webhook URL to: http://localhost:3001/webhook
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# --- OpenCode Server ---
# URL of the running `opencode serve` instance
OPENCODE_URL=http://localhost:4096
OPENCODE_PASSWORD=

# --- Session Store ---
# For MVP: "file" (JSON on disk). Later: "redis", "firestore"
SESSION_STORE=file
SESSION_STORE_PATH=./data/sessions.json

# --- Agent Defaults ---
# Default agent when no label/command specifies one
DEFAULT_AGENT=sisyphus
# Agent used for /start-work execution (hidden from user)
EXECUTOR_AGENT=atlas

# --- Multi-App Mode (optional) ---
# Register separate Linear OAuth apps per agent (e.g. @Prometheus, @Sisyphus)
# Each app appears as a separate assignable user in Linear
# JSON mapping keyed by oauthClientId:
# AGENT_APPS={"client_id_1":{"clientId":"...","clientSecret":"...","webhookSecret":"...","defaultAgent":"prometheus"},"client_id_2":{"clientId":"...","clientSecret":"...","webhookSecret":"...","defaultAgent":"sisyphus"}}


# --- Optional: GCP (for production) ---
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
