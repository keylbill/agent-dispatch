{
	"name": "agent-dispatch",
	"version": "0.1.0",
	"description": "Bridge between Linear and OpenCode — assign tickets to AI agents, get work done.",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"check": "bun run biome check .",
		"check:fix": "bun run biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@linear/sdk": "^80.0.0",
		"@opencode-ai/sdk": "^1.3.3",
		"hono": "^4.7.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.2.0",
		"typescript": "^5.7.0"
	}
}
